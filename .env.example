# --- OpenAI (motor) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5
# minimal | low | medium | high — profundidade de raciocínio do gpt-5.
OPENAI_REASONING_EFFORT=medium
# Teto da resposta (inclui tokens de raciocínio); folga pra não truncar o JSON.
OPENAI_MAX_TOKENS=16000
OPENAI_TIMEOUT_MS=45000

# --- ClickUp (orquestração) ---
CLICKUP_API_TOKEN=pk_...
CLICKUP_WORKSPACE_ID=
# Status que DISPARA o motor (configurado no webhook do ClickUp).
CLICKUP_STATUS_REVISAR_PREFERENCIA=revisar preferência
# Para onde a task vai depois (sempre, inclusive em falha).
CLICKUP_STATUS_REVISADO=revisado
# Id do custom field dropdown "Cliente".
CLICKUP_CAMPO_CLIENTE_ID=

# --- Perfil ---
# clickup (produção) | local (harness)
PERFIL_FONTE=clickup
PERFIL_DIR_LOCAL=perfis
# Mapa cliente -> docId do ClickUp (JSON). Chaves podem ser o nome humano.
# Ex.: PERFIL_DOCS={"Dr. Macário":"8cdef-123","Malhas Kid":"8cdef-456"}
PERFIL_DOCS={}

# --- Servidor ---
PORT=3000
